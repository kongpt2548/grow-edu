<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>คอร์สเรียนของฉัน - Grow EDU</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600&display=swap" rel="stylesheet">
    <style>body { font-family: 'Kanit', sans-serif; }</style>
</head>
<body class="bg-gray-100">
    <div class="flex h-screen">
        <aside class="w-64 bg-white shadow-md hidden md:block">
            <div class="p-6 font-bold text-xl text-[#1A73E8]">Grow EDU (Student)</div>
            <nav class="mt-6">
                <a href="/student" class="block py-3 px-6 bg-blue-50 text-[#1A73E8] border-r-4 border-[#1A73E8]">คอร์สของฉัน</a>
                <a href="/courses" class="block py-3 px-6 text-gray-600 hover:bg-gray-50">เลือกซื้อคอร์สเพิ่ม</a>
                <a href="/login" class="block py-3 px-6 text-red-500 mt-10">ออกจากระบบ</a>
            </nav>
        </aside>

        <main class="flex-1 overflow-y-auto p-8">
            <div class="flex justify-between items-center mb-8">
                <h1 class="text-2xl font-bold text-gray-800">ห้องเรียนของคุณ 🎒</h1>
            </div>

            <% if (orders.length === 0) { %>
                <div class="text-center py-20 bg-white rounded-3xl shadow-sm border border-gray-100">
                    <div class="text-6xl mb-4">🛒</div>
                    <h3 class="text-xl font-bold text-gray-500 mb-2">คุณยังไม่มีคอร์สเรียน</h3>
                    <a href="/courses" class="text-[#1A73E8] font-bold hover:underline">ไปเลือกซื้อคอร์สเรียนกันเลย!</a>
                </div>
            <% } else { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% orders.forEach(order => { %>
                        <% if(order.videoId) { %>
                            <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition flex flex-col justify-between">
                                <div>
                                    <span class="text-xs font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full"><%= order.videoId.subject %></span>
                                    <h3 class="font-bold text-lg mt-3 mb-1"><%= order.videoId.title %></h3>
                                    <p class="text-sm text-gray-500 mb-4">ติวเตอร์: <%= order.videoId.tutorId.username %></p>
                                </div>
                                
                                <a href="https://drive.google.com/file/d/<%= order.videoId.driveFileId %>/view" target="_blank" class="w-full text-center bg-green-500 hover:bg-green-600 text-white font-bold py-2 rounded-xl mt-2 transition">
                                    ▶️ เข้าเรียนเลย
                                </a>
                            </div>
                        <% } %>
                    <% }) %>
                </div>
            <% } %>
        </main>
    </div>
</body>
</html>