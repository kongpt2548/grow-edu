<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>เลือกคลิปเรียน - Grow EDU</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600&display=swap" rel="stylesheet">
    <style>body { font-family: 'Kanit', sans-serif; }</style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
    <div class="max-w-6xl mx-auto p-8 w-full flex-grow">
        <div class="flex justify-start mb-6">
            <a href="/courses/<%= level %>" class="text-[#1A73E8] font-bold hover:underline">⬅️ กลับหน้าเลือกวิชา</a>
        </div>

        <h1 class="text-3xl font-bold mb-8">บทเรียน: <%= subject %> (<span class="text-[#1A73E8]"><%= level %></span>)</h1>

        <% if (videos.length === 0) { %>
            <div class="text-center py-20 bg-white rounded-3xl shadow-sm border-2 border-dashed border-gray-300">
                <div class="text-6xl mb-4">📭</div>
                <h3 class="text-xl font-bold text-gray-500">ขณะนี้ยังไม่มีคลิปสอนในวิชานี้</h3>
                <p class="text-gray-400">ติวเตอร์กำลังเตรียมเนื้อหา รอติดตามเร็วๆ นี้นะครับ</p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <% videos.forEach(video => { %>
                    <div class="bg-white rounded-2xl shadow-sm border p-5 flex flex-col justify-between hover:shadow-lg transition">
                        <div>
                            <div class="aspect-video bg-gray-200 rounded-xl mb-4 flex items-center justify-center text-gray-400">
                                <i class="fa-solid fa-play text-4xl"></i>
                            </div>
                            <h4 class="font-bold text-lg mb-1"><%= video.title %></h4>
                            <p class="text-sm text-gray-500 mb-4">สอนโดย: ติวเตอร์ <%= video.tutorId.username %></p>
                        </div>
                        <div class="mt-4 flex justify-between items-center border-t pt-4">
                            <span class="text-xl font-black text-green-600">฿<%= video.price %></span>
                            <a href="/checkout/<%= video._id %>" class="bg-[#1A73E8] hover:bg-blue-700 text-white px-6 py-2 rounded-xl font-bold transition">ซื้อคอร์สนี้</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</body>
</html>