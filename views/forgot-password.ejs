<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ลืมรหัสผ่าน - Grow EDU</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-[#E1F5FE] flex items-center justify-center min-h-screen p-4 font-sans selection:bg-[#1A73E8] selection:text-white">

    <div class="bg-white p-6 md:p-10 rounded-3xl shadow-xl w-full max-w-md border-t-4 border-[#1A73E8]">
        
        <h1 class="text-2xl md:text-3xl font-bold text-center text-[#1A73E8] mb-8"><i class="fa-solid fa-unlock-keyhole mr-2"></i> กู้คืนรหัสผ่าน</h1>

        <div id="step-1">
            <p class="text-gray-500 text-sm mb-6 text-center">กรอกอีเมลที่ใช้สมัครสมาชิก ระบบจะส่งรหัส OTP ไปให้ครับ</p>
            <div class="mb-6">
                <label class="block text-sm text-gray-700 mb-2 font-medium">อีเมลของคุณ</label>
                <div class="relative group">
                    <i class="fa-solid fa-envelope absolute left-4 top-3.5 text-gray-400"></i>
                    <input type="email" id="email" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl py-3 pl-11 pr-4 focus:outline-none focus:border-[#1A73E8] transition" placeholder="example@gmail.com">
                </div>
            </div>
            <button onclick="sendOTP()" id="btn-send" class="w-full bg-[#1A73E8] hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-md transition text-lg">
                ส่งรหัส OTP
            </button>
        </div>

        <div id="step-2" class="hidden space-y-5">
            <div class="bg-blue-50 p-4 rounded-xl border border-blue-200 text-center">
                <p class="text-[#1A73E8] text-sm font-bold"><i class="fa-solid fa-envelope-open-text mr-1"></i> ระบบส่งรหัสไปแล้ว</p>
                <p class="text-gray-600 text-xs mt-1">กรุณานำรหัส 6 หลักจากอีเมลมากรอกด้านล่าง</p>
            </div>
            
            <div>
                <label class="block text-sm text-gray-700 mb-2 font-medium text-center">รหัส OTP (6 หลัก)</label>
                <input type="text" id="otp" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl p-3 text-center text-3xl tracking-[0.5em] font-mono focus:border-[#1A73E8] outline-none" maxlength="6" placeholder="------">
            </div>
            <div>
                <label class="block text-sm text-gray-700 mb-2 font-medium">ตั้งรหัสผ่านใหม่</label>
                <div class="relative group">
                    <i class="fa-solid fa-lock absolute left-4 top-3.5 text-gray-400"></i>
                    <input type="password" id="new-password" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl py-3 pl-11 pr-12 focus:border-[#1A73E8] outline-none transition" placeholder="รหัสผ่านใหม่">
                    <i class="fa-solid fa-eye-slash absolute right-4 top-3.5 text-gray-400 cursor-pointer hover:text-[#1A73E8]" onclick="togglePwd('new-password', this)"></i>
                </div>
            </div>
            <div>
                <label class="block text-sm text-gray-700 mb-2 font-medium">ยืนยันรหัสผ่านใหม่</label>
                <div class="relative group">
                    <i class="fa-solid fa-lock-open absolute left-4 top-3.5 text-gray-400"></i>
                    <input type="password" id="confirm-password" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl py-3 pl-11 pr-12 focus:border-[#1A73E8] outline-none transition" placeholder="พิมพ์ให้ตรงกันอีกครั้ง">
                    <i class="fa-solid fa-eye-slash absolute right-4 top-3.5 text-gray-400 cursor-pointer hover:text-[#1A73E8]" onclick="togglePwd('confirm-password', this)"></i>
                </div>
            </div>
            
            <button onclick="confirmReset()" id="btn-reset" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-4 rounded-xl shadow-md transition text-lg mt-2">
                ยืนยันเปลี่ยนรหัสผ่าน
            </button>
            <div class="text-center pt-4 border-t border-gray-200 mt-4">
                <button onclick="location.reload()" class="text-sm text-gray-500 hover:text-gray-800 font-bold transition">
                    <i class="fa-solid fa-rotate-left"></i> เริ่มใหม่ / ขอรหัสใหม่
                </button>
            </div>
        </div>

        <div class="mt-8 text-center text-sm">
            <a href="/login" class="text-[#1A73E8] hover:underline font-bold"><i class="fa-solid fa-arrow-left mr-1"></i> กลับไปหน้าเข้าสู่ระบบ</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function togglePwd(inputId, icon) {
            const input = document.getElementById(inputId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('fa-eye-slash', 'fa-eye');
                icon.classList.add('text-[#1A73E8]');
            } else {
                input.type = "password";
                icon.classList.replace('fa-eye', 'fa-eye-slash');
                icon.classList.remove('text-[#1A73E8]');
            }
        }

        function sendOTP() {
            const email = document.getElementById('email').value.toLowerCase().trim();
            const btn = document.getElementById('btn-send');

            if (!email) return Swal.fire('แจ้งเตือน', 'กรุณากรอกอีเมล', 'warning');

            btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> กำลังส่ง...';
            btn.disabled = true;

            fetch('/forgot-password', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email })
            }).then(async res => {
                const data = await res.json();
                if (!res.ok) throw new Error(data.message);
                
                Swal.fire({icon: 'success', title: 'ส่งรหัสแล้ว', text: 'กรุณาเช็คอีเมล (รวมถึง Junk/Spam)', timer: 2000, showConfirmButton: false});
                document.getElementById('step-1').classList.add('hidden');
                document.getElementById('step-2').classList.remove('hidden');
            }).catch(err => {
                Swal.fire('ผิดพลาด', err.message, 'error');
                btn.innerHTML = 'ส่งรหัส OTP'; btn.disabled = false;
            });
        }

        function confirmReset() {
            const email = document.getElementById('email').value;
            const otp = document.getElementById('otp').value;
            const newPassword = document.getElementById('new-password').value;
            const confirmPassword = document.getElementById('confirm-password').value;
            const btn = document.getElementById('btn-reset');

            if(!otp || !newPassword || !confirmPassword) return Swal.fire('แจ้งเตือน', 'กรุณากรอกข้อมูลให้ครบ', 'warning');
            if(newPassword !== confirmPassword) return Swal.fire('รหัสผ่านไม่ตรงกัน', 'กรุณายืนยันรหัสผ่านให้เหมือนกันทั้งสองช่อง', 'error');

            btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> กำลังเปลี่ยน...'; btn.disabled = true;

            fetch('/reset-password', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, otp, newPassword })
            }).then(res => res.json()).then(data => {
                if(data.message.includes('สำเร็จ')) {
                    Swal.fire({icon:'success', title:'สำเร็จ!', text:'เปลี่ยนรหัสผ่านเรียบร้อยแล้ว'}).then(() => window.location.href = '/login');
                } else {
                    Swal.fire('ผิดพลาด', data.message, 'error');
                    btn.innerHTML = 'ยืนยันเปลี่ยนรหัสผ่าน'; btn.disabled = false;
                }
            }).catch(() => {
                Swal.fire('Error', 'เกิดข้อผิดพลาด', 'error');
                btn.innerHTML = 'ยืนยันเปลี่ยนรหัสผ่าน'; btn.disabled = false;
            });
        }
    </script>
</body>
</html>