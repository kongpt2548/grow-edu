<div class="p-8">
    <h2 class="text-2xl font-bold mb-6">💰 รายได้และสถิติของคุณ</h2>
    
    <div class="bg-green-100 p-6 rounded-xl mb-8">
        <p class="text-green-800">รายได้สะสมที่ถอนได้ (คิดเป็น 60%)</p>
        <h1 class="text-4xl font-bold text-green-700">฿ <%= user.balance.toFixed(2) %></h1>
    </div>

    <h3 class="font-bold mb-4">ประวัติการอัปโหลดคลิป</h3>
    <table class="w-full bg-white rounded-lg overflow-hidden shadow">
        <thead class="bg-gray-100">
            <tr>
                <th class="p-3 text-left">ชื่อคลิป</th>
                <th class="p-3 text-left">สถานะ</th>
                <th class="p-3 text-left">จำนวนคนซื้อ/ดู</th>
                <th class="p-3 text-left">ยอดเงิน (60%)</th>
            </tr>
        </thead>
        <tbody>
            <% videos.forEach(video => { %>
            <tr class="border-t">
                <td class="p-3"><%= video.title %></td>
                <td class="p-3">
                    <span class="<%= video.status === 'approved' ? 'text-green-500' : 'text-orange-500' %>">
                        <%= video.status === 'approved' ? 'อนุมัติแล้ว' : 'รอตรวจสอบ' %>
                    </span>
                </td>
                <td class="p-3"><%= video.views %> User</td>
                <td class="p-3">฿ <%= (video.views * video.price * 0.6).toFixed(2) %></td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>