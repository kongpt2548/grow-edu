<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>ชำระค่าบริการ - Grow EDU</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen p-4 font-sans">
    
    <div class="bg-white p-8 rounded-3xl shadow-xl w-full max-w-md border-t-4 border-[#1A73E8] text-center">
        <h2 class="text-2xl font-bold text-gray-800 mb-2">ชำระค่าคอร์สเรียน</h2>
        <p class="text-gray-500 mb-6 text-sm"><%= video.title %></p>

        <div class="bg-gray-50 p-5 rounded-2xl mb-6 border-2 border-gray-200 shadow-inner relative overflow-hidden transform transition hover:scale-105 duration-300">
            <div class="bg-white p-2 rounded-xl inline-block shadow-sm border border-gray-100">
                <img id="manual-qr-image" class="w-48 h-48 mx-auto object-contain" src="/api/qr/<%= video.price %>" alt="PromptPay QR">
            </div>
            <div class="mt-4 text-sm text-gray-500 font-medium">สแกนเพื่อชำระเงินจำนวน</div>
            <div class="text-3xl font-black text-[#1A73E8] drop-shadow-sm mt-1">฿<%= video.price %></div>
        </div>

        <div class="text-left mb-6">
            <label class="block text-sm font-bold text-gray-700 mb-2">แนบสลิปโอนเงิน <span class="text-red-500 text-xs font-normal">(ไม่เกิน 2MB)</span></label>
            <input type="file" id="slip-file" accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-bold file:bg-blue-50 file:text-[#1A73E8] hover:file:bg-blue-100 transition border-2 border-gray-200 p-2 rounded-xl focus-within:border-[#1A73E8] shadow-inner">
        </div>

        <button id="btn-submit" onclick="submitPayment()" class="w-full bg-[#1A73E8] hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg transition text-lg flex justify-center items-center gap-2">
            <i class="fa-solid fa-paper-plane"></i> ยืนยันการชำระเงิน
        </button>

        <a href="/courses" class="block mt-4 text-sm text-gray-400 hover:text-gray-600 hover:underline">ยกเลิกและกลับไปเลือกคอร์ส</a>
    </div>

    <script>
        function submitPayment() {
            const fileInput = document.getElementById('slip-file').files[0];
            if (!fileInput) return Swal.fire('แจ้งเตือน', 'กรุณาแนบรูปสลิปโอนเงิน', 'warning');

            if (fileInput.size > 2 * 1024 * 1024) {
                return Swal.fire('ไฟล์ใหญ่เกินไป', 'รูปสลิปต้องมีขนาดไม่เกิน 2 MB ครับ', 'warning');
            }

            const btn = document.getElementById('btn-submit');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> กำลังส่งข้อมูล...'; 
            btn.disabled = true;

            const reader = new FileReader();
            reader.onload = function(e) {
                fetch('/api/submit-payment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        videoId: '<%= video._id %>',
                        amount: Number('<%= video.price %>'),
                        slipImage: e.target.result
                    })
                })
                .then(res => res.json())
                .then(data => {
                    Swal.fire({icon: 'success', title: 'สำเร็จ', text: data.message}).then(() => {
                        window.location.href = '/student';
                    });
                })
                .catch(() => {
                    Swal.fire('Error', 'เกิดข้อผิดพลาด', 'error');
                    btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> ยืนยันการชำระเงิน';
                    btn.disabled = false;
                });
            };
            reader.readAsDataURL(fileInput);
        }
    </script>
</body>
</html>