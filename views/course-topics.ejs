<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>เลือกวิชา - Grow EDU</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600&display=swap" rel="stylesheet">
    <style>body { font-family: 'Kanit', sans-serif; }</style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
    <div class="max-w-4xl mx-auto p-8 text-center flex-grow w-full">
        <div class="flex justify-start mb-6">
            <a href="/courses" class="text-[#1A73E8] font-bold hover:underline">⬅️ กลับหน้าระดับชั้น</a>
        </div>
        
        <h1 class="text-3xl font-bold mb-8 text-gray-800">วิชาที่ต้องการเรียน (<span class="text-[#1A73E8]"><%= level %></span>)</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <a href="/courses/<%= level %>/คณิตศาสตร์" class="bg-white p-6 rounded-2xl shadow hover:shadow-lg border-2 border-transparent hover:border-[#1A73E8] transition text-xl font-bold text-gray-700">📐 คณิตศาสตร์</a>
            <a href="/courses/<%= level %>/ภาษาไทย" class="bg-white p-6 rounded-2xl shadow hover:shadow-lg border-2 border-transparent hover:border-[#1A73E8] transition text-xl font-bold text-gray-700">📖 ภาษาไทย</a>
            <a href="/courses/<%= level %>/วิทยาศาสตร์" class="bg-white p-6 rounded-2xl shadow hover:shadow-lg border-2 border-transparent hover:border-[#1A73E8] transition text-xl font-bold text-gray-700">🔬 วิทยาศาสตร์</a>
            <a href="/courses/<%= level %>/อังกฤษ" class="bg-white p-6 rounded-2xl shadow hover:shadow-lg border-2 border-transparent hover:border-[#1A73E8] transition text-xl font-bold text-gray-700">🔤 อังกฤษ</a>

            <% if (level === 'มัธยมต้น') { %>
                <a href="/courses/<%= level %>/ติวสอบเข้าม.4" class="bg-blue-100 p-6 rounded-2xl shadow hover:shadow-lg border-2 border-transparent hover:border-[#1A73E8] transition text-xl font-bold text-[#1A73E8] md:col-span-2">🎯 ติวสอบเข้า ม.4</a>
            <% } %>

            <% if (level === 'มัธยมปลาย') { %>
                <a href="/courses/<%= level %>/เคมี" class="bg-white p-6 rounded-2xl shadow hover:shadow-lg border-2 border-transparent hover:border-[#1A73E8] transition text-xl font-bold text-gray-700">🧪 เคมี</a>
                <a href="/courses/<%= level %>/ฟิสิกส์" class="bg-white p-6 rounded-2xl shadow hover:shadow-lg border-2 border-transparent hover:border-[#1A73E8] transition text-xl font-bold text-gray-700">⚙️ ฟิสิกส์</a>
                <a href="/courses/<%= level %>/ชีววิทยา" class="bg-white p-6 rounded-2xl shadow hover:shadow-lg border-2 border-transparent hover:border-[#1A73E8] transition text-xl font-bold text-gray-700">🌿 ชีววิทยา</a>
                <a href="/courses/<%= level %>/ติวสอบเข้ามหาลัย" class="bg-blue-100 p-6 rounded-2xl shadow hover:shadow-lg border-2 border-transparent hover:border-[#1A73E8] transition text-xl font-bold text-[#1A73E8] md:col-span-2">🎓 ติวสอบเข้ามหาลัย (TCAS)</a>
            <% } %>
        </div>
    </div>
</body>
</html>