<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tutor Dashboard - Grow EDU</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>body { font-family: 'Kanit', sans-serif; }</style>
</head>
<body class="bg-[#F8F9FA] flex h-screen overflow-hidden">
    
    <div id="mobile-overlay" class="fixed inset-0 bg-gray-900 bg-opacity-50 z-40 hidden md:hidden" onclick="toggleSidebar()"></div>

    <aside id="sidebar" class="w-64 bg-[#1E293B] text-white flex-shrink-0 fixed md:relative h-full z-50 transform -translate-x-full md:translate-x-0 transition-transform duration-300">
        <div class="p-6 font-bold text-xl text-blue-400 flex justify-between items-center border-b border-gray-700">
            Grow EDU (Tutor)
            <button class="md:hidden text-gray-400 hover:text-red-400 transition" onclick="toggleSidebar()"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <nav class="mt-6">
            <a href="/tutor" class="block py-4 px-6 bg-blue-600 font-bold border-r-4 border-blue-300"><i class="fa-solid fa-chart-pie mr-2"></i> แผงควบคุม</a>
            <a href="/tutor/upload" class="block py-4 px-6 hover:bg-gray-700 transition"><i class="fa-solid fa-cloud-arrow-up mr-2"></i> อัปโหลดคลิปสอน</a>
            <a href="/tutor/income" class="block py-4 px-6 hover:bg-gray-700 text-orange-400 transition"><i class="fa-solid fa-wallet mr-2"></i> รายได้</a>
            <a href="/login" class="block py-4 px-6 text-red-400 mt-10 hover:bg-gray-700 transition"><i class="fa-solid fa-right-from-bracket mr-2"></i> ออกจากระบบ</a>
        </nav>
    </aside>

    <main class="flex-1 flex flex-col h-screen overflow-hidden text-gray-800">
        
        <header class="md:hidden bg-white shadow-sm p-4 flex justify-between items-center flex-shrink-0 z-30">
            <div class="font-black text-xl text-blue-600">Grow EDU (Tutor)</div>
            <button onclick="toggleSidebar()" class="text-gray-600 hover:text-blue-600 text-2xl transition"><i class="fa-solid fa-bars"></i></button>
        </header>

        <div class="flex-1 overflow-y-auto p-6 md:p-10">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10">
                <h1 class="text-2xl md:text-3xl font-bold"><i class="fa-solid fa-chalkboard-user text-blue-600 mr-2"></i> หน้าจัดการสำหรับติวเตอร์</h1>
                <a href="/tutor/upload" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold shadow-md hover:bg-blue-700 transition w-full md:w-auto text-center flex items-center justify-center gap-2">
                    <i class="fa-solid fa-plus"></i> สร้างคอร์สใหม่
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
                <div class="bg-white p-8 rounded-3xl shadow-sm border-l-8 border-blue-500 flex items-center justify-between hover:shadow-md transition">
                    <div>
                        <p class="text-gray-500 font-bold mb-1">นักเรียนที่ซื้อคอร์ส</p>
                        <p class="text-4xl font-black text-gray-800"><%= typeof totalStudents !== 'undefined' ? totalStudents : 0 %> <span class="text-lg font-normal text-gray-500">คน</span></p>
                    </div>
                    <i class="fa-solid fa-users text-5xl text-blue-100"></i>
                </div>
                <div class="bg-white p-8 rounded-3xl shadow-sm border-l-8 border-orange-500 flex items-center justify-between hover:shadow-md transition">
                    <div>
                        <p class="text-gray-500 font-bold mb-1">รายได้สะสม (60%)</p>
                        <p class="text-4xl font-black text-orange-500">฿<%= typeof totalRevenue !== 'undefined' ? totalRevenue.toLocaleString('th-TH', {minimumFractionDigits: 2}) : '0.00' %></p>
                    </div>
                    <i class="fa-solid fa-coins text-5xl text-orange-100"></i>
                </div>
            </div>
        </div>
    </main>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobile-overlay');
            sidebar.classList.toggle('-translate-x-full');
            overlay.classList.toggle('hidden');
        }
    </script>
</body>
</html>