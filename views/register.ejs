<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>สมัครสมาชิก - Grow EDU</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-[#E1F5FE] flex items-center justify-center min-h-screen p-4 font-sans selection:bg-[#1A73E8] selection:text-white">

    <div class="bg-white p-6 md:p-10 rounded-3xl shadow-xl w-full max-w-md border-t-4 border-[#1A73E8]">
        <h1 class="text-2xl md:text-3xl font-bold text-center text-[#1A73E8] mb-8"><i class="fa-solid fa-user-plus mr-2"></i> สมัครสมาชิก</h1>

        <form id="register-form" onsubmit="event.preventDefault();" class="space-y-4">
            <div id="step-1" class="space-y-4">
                
                <div>
                    <label class="block text-sm text-gray-700 font-medium mb-1">ชื่อผู้ใช้ (Username)</label>
                    <div class="relative group">
                        <i class="fa-solid fa-user absolute left-4 top-3.5 text-gray-400"></i>
                        <input type="text" id="username" onkeyup="checkUsername()" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl py-3 pl-11 pr-4 text-gray-800 focus:outline-none focus:border-[#1A73E8] transition" placeholder="ตั้งชื่อผู้ใช้ของคุณ">
                    </div>
                    <div id="username-msg" class="text-xs mt-1.5 hidden ml-1 font-medium"></div>
                </div>

                <div>
                    <label class="block text-sm text-gray-700 font-medium mb-1">อีเมล (Email)</label>
                    <div class="relative group">
                        <i class="fa-solid fa-envelope absolute left-4 top-3.5 text-gray-400"></i>
                        <input type="email" id="email" onkeyup="checkEmail()" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl py-3 pl-11 pr-4 text-gray-800 focus:outline-none focus:border-[#1A73E8] transition" placeholder="example@email.com">
                    </div>
                    <div id="email-msg" class="text-xs mt-1.5 hidden ml-1 font-medium"></div>
                </div>

                <div>
                    <label class="block text-sm text-gray-700 font-medium mb-1">รหัสผ่าน (Password)</label>
                    <div class="relative group">
                        <i class="fa-solid fa-lock absolute left-4 top-3.5 text-gray-400"></i>
                        <input type="password" id="password" onkeyup="checkPassword()" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl py-3 pl-11 pr-12 text-gray-800 focus:outline-none focus:border-[#1A73E8] transition" placeholder="ตั้งรหัสผ่าน">
                        <i class="fa-solid fa-eye-slash absolute right-4 top-3.5 text-gray-400 cursor-pointer hover:text-[#1A73E8]" onclick="togglePwd('password', this)"></i>
                    </div>
                    <div id="password-rules" class="text-xs mt-2 grid grid-cols-2 gap-1 ml-1 text-gray-500">
                        <div id="rule-length"><i class="fa-solid fa-circle-xmark text-red-500 mr-1"></i> อย่างน้อย 8 ตัวอักษร</div>
                        <div id="rule-upper"><i class="fa-solid fa-circle-xmark text-red-500 mr-1"></i> มีตัวพิมพ์ใหญ่ (A-Z)</div>
                        <div id="rule-lower"><i class="fa-solid fa-circle-xmark text-red-500 mr-1"></i> มีตัวพิมพ์เล็ก (a-z)</div>
                        <div id="rule-special"><i class="fa-solid fa-circle-xmark text-red-500 mr-1"></i> อักขระพิเศษ/ตัวเลข</div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm text-gray-700 font-medium mb-1">ยืนยันรหัสผ่าน</label>
                    <div class="relative group">
                        <i class="fa-solid fa-lock-open absolute left-4 top-3.5 text-gray-400"></i>
                        <input type="password" id="confirm-password" onkeyup="checkConfirmPassword()" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl py-3 pl-11 pr-12 text-gray-800 focus:outline-none focus:border-[#1A73E8] transition" placeholder="พิมพ์รหัสให้ตรงกัน">
                        <i class="fa-solid fa-eye-slash absolute right-4 top-3.5 text-gray-400 cursor-pointer hover:text-[#1A73E8]" onclick="togglePwd('confirm-password', this)"></i>
                    </div>
                    <div id="confirm-msg" class="text-xs mt-1.5 hidden ml-1 font-medium"></div>
                </div>

                <div>
                    <label class="block text-sm text-gray-700 font-medium mb-1">สมัครในฐานะ</label>
                    <select id="role" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl py-3 px-4 text-gray-800 focus:outline-none focus:border-[#1A73E8] transition">
                        <option value="student">👨‍🎓 นักเรียน</option>
                        <option value="tutor">👨‍🏫 ติวเตอร์</option>
                    </select>
                </div>

                <button type="button" onclick="requestOTP()" id="btn-request" class="w-full bg-gray-300 text-gray-500 font-bold py-4 rounded-xl transition mt-4 text-lg cursor-not-allowed" disabled>
                    กรอกข้อมูลให้ครบถ้วน
                </button>
            </div>

            <div id="step-2" class="hidden space-y-5">
                <div class="bg-blue-50 p-4 rounded-xl border border-blue-200 text-center">
                    <p class="text-[#1A73E8] text-sm font-bold"><i class="fa-solid fa-envelope-circle-check mr-1 text-lg"></i> ส่งรหัสไปที่อีเมลแล้ว</p>
                    <p class="text-gray-600 text-xs mt-1" id="display-email">...</p>
                    <div class="mt-2 text-xs font-mono text-orange-600 bg-orange-100 inline-block px-3 py-1 rounded border border-orange-200">Ref: <span id="ref-code">XXXX</span></div>
                </div>
                
                <div>
                    <label class="block text-sm text-gray-700 mb-2 font-medium text-center">รหัส OTP (6 หลัก)</label>
                    <input type="text" id="otp" class="w-full bg-gray-50 border-2 border-gray-200 rounded-xl p-4 text-gray-800 text-center text-3xl tracking-[0.5em] font-mono focus:border-[#1A73E8] outline-none" maxlength="6" placeholder="------">
                </div>
                
                <button type="button" onclick="confirmRegister()" id="btn-register" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-4 rounded-xl transition text-lg flex justify-center items-center gap-2">
                    <i class="fa-solid fa-user-check"></i> ยืนยันการสมัคร
                </button>

                <div class="text-center pt-2 border-t border-gray-200 mt-4 flex justify-between items-center px-2">
                    <button type="button" onclick="backToStep1()" class="text-sm text-gray-500 hover:text-[#1A73E8] transition">
                        <i class="fa-solid fa-arrow-left"></i> แก้ไขข้อมูล
                    </button>
                    <button type="button" onclick="requestOTP(true)" id="btn-resend" class="text-sm text-gray-400 font-bold transition" disabled>
                        ขอรหัสใหม่ <span id="countdown" class="font-mono">01:00</span>
                    </button>
                </div>
            </div>
        </form>
        <div class="mt-6 text-center text-sm text-gray-600 border-t border-gray-200 pt-4">
            มีบัญชีแล้ว? <a href="/login" class="text-[#1A73E8] hover:underline font-bold ml-1">เข้าสู่ระบบเลย</a>
        </div>
    </div>

    <script>
        let isValid = { user: false, email: false, pass: false, conf: false };
        let typingTimer; 
        let countdownInterval;

        function togglePwd(inputId, icon) {
            const input = document.getElementById(inputId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('fa-eye-slash', 'fa-eye');
                icon.classList.add('text-[#1A73E8]');
            } else {
                input.type = "password";
                icon.classList.replace('fa-eye', 'fa-eye-slash');
                icon.classList.remove('text-[#1A73E8]');
            }
        }

        function checkAllValid() {
            const btn = document.getElementById('btn-request');
            if (isValid.user && isValid.email && isValid.pass && isValid.conf) {
                btn.disabled = false;
                btn.className = "w-full bg-[#1A73E8] hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg transition mt-6 text-lg flex justify-center items-center gap-2";
                btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> รับรหัส OTP ทางอีเมล';
            } else {
                btn.disabled = true;
                btn.className = "w-full bg-gray-300 text-gray-500 font-bold py-4 rounded-xl transition mt-6 text-lg cursor-not-allowed";
                btn.innerHTML = 'กรอกข้อมูลให้ครบถ้วนเพื่อไปต่อ';
            }
        }

        function checkUsername() {
            clearTimeout(typingTimer);
            const input = document.getElementById('username');
            const msg = document.getElementById('username-msg');
            const val = input.value.trim();

            if (val.length < 3) {
                msg.innerHTML = '<span class="text-red-500"><i class="fa-solid fa-circle-xmark"></i> 3 ตัวอักษรขึ้นไป</span>';
                msg.classList.remove('hidden');
                input.classList.replace('border-gray-200', 'border-red-500');
                input.classList.replace('border-green-500', 'border-red-500');
                isValid.user = false; checkAllValid(); return;
            }

            typingTimer = setTimeout(() => {
                fetch('/api/check-username', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username: val })
                }).then(res => res.json()).then(data => {
                    if (data.available) {
                        msg.innerHTML = '<span class="text-green-600"><i class="fa-solid fa-circle-check"></i> ใช้งานได้</span>';
                        input.classList.replace('border-red-500', 'border-green-500');
                        input.classList.replace('border-gray-200', 'border-green-500');
                        isValid.user = true;
                    } else {
                        msg.innerHTML = `<span class="text-red-500"><i class="fa-solid fa-circle-xmark"></i> ${data.message}</span>`;
                        input.classList.replace('border-green-500', 'border-red-500');
                        input.classList.replace('border-gray-200', 'border-red-500');
                        isValid.user = false;
                    }
                    msg.classList.remove('hidden'); checkAllValid();
                });
            }, 500);
        }

        function checkEmail() {
            clearTimeout(typingTimer);
            const input = document.getElementById('email');
            const msg = document.getElementById('email-msg');
            const val = input.value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!emailRegex.test(val)) {
                msg.innerHTML = '<span class="text-red-500"><i class="fa-solid fa-circle-xmark"></i> รูปแบบไม่ถูกต้อง</span>';
                msg.classList.remove('hidden');
                input.classList.replace('border-gray-200', 'border-red-500');
                input.classList.replace('border-green-500', 'border-red-500');
                isValid.email = false; checkAllValid(); return;
            }

            typingTimer = setTimeout(() => {
                fetch('/api/check-email', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: val })
                }).then(res => res.json()).then(data => {
                    if (data.available) {
                        msg.innerHTML = '<span class="text-green-600"><i class="fa-solid fa-circle-check"></i> ใช้งานได้</span>';
                        input.classList.replace('border-red-500', 'border-green-500');
                        input.classList.replace('border-gray-200', 'border-green-500');
                        isValid.email = true;
                    } else {
                        msg.innerHTML = '<span class="text-red-500"><i class="fa-solid fa-circle-xmark"></i> อีเมลซ้ำ</span>';
                        input.classList.replace('border-green-500', 'border-red-500');
                        input.classList.replace('border-gray-200', 'border-red-500');
                        isValid.email = false;
                    }
                    msg.classList.remove('hidden'); checkAllValid();
                });
            }, 500);
        }

        function checkPassword() {
            const val = document.getElementById('password').value;
            const rLen = val.length >= 8;
            const rUp = /[A-Z]/.test(val);
            const rLow = /[a-z]/.test(val);
            const rSpec = /[^A-Za-z0-9]/.test(val) || /[0-9]/.test(val); 

            function updateRule(id, passed) {
                const el = document.getElementById(id);
                if(passed) el.innerHTML = '<i class="fa-solid fa-circle-check text-green-500 mr-1"></i><span class="text-green-600"> ' + el.innerText.trim() + '</span>';
                else el.innerHTML = '<i class="fa-solid fa-circle-xmark text-red-500 mr-1"></i><span class="text-gray-500"> ' + el.innerText.trim() + '</span>';
            }

            updateRule('rule-length', rLen);
            updateRule('rule-upper', rUp);
            updateRule('rule-lower', rLow);
            updateRule('rule-special', rSpec);

            const input = document.getElementById('password');
            if (rLen && rUp && rLow && rSpec) {
                input.classList.replace('border-gray-200', 'border-green-500');
                input.classList.replace('border-red-500', 'border-green-500');
                isValid.pass = true;
            } else {
                input.classList.replace('border-green-500', 'border-red-500');
                input.classList.replace('border-gray-200', 'border-red-500');
                isValid.pass = false;
            }
            checkConfirmPassword(); checkAllValid();
        }

        function checkConfirmPassword() {
            const pass = document.getElementById('password').value;
            const conf = document.getElementById('confirm-password').value;
            const input = document.getElementById('confirm-password');
            const msg = document.getElementById('confirm-msg');

            if (conf === '') { 
                isValid.conf = false; msg.classList.add('hidden'); 
                input.classList.replace('border-green-500', 'border-gray-200'); 
                input.classList.replace('border-red-500', 'border-gray-200'); 
                checkAllValid(); return; 
            }

            if (pass === conf && isValid.pass) {
                msg.innerHTML = '<span class="text-green-600"><i class="fa-solid fa-circle-check"></i> ตรงกัน</span>';
                input.classList.replace('border-gray-200', 'border-green-500');
                input.classList.replace('border-red-500', 'border-green-500');
                isValid.conf = true;
            } else {
                msg.innerHTML = '<span class="text-red-500"><i class="fa-solid fa-circle-xmark"></i> ไม่ตรงกัน</span>';
                input.classList.replace('border-green-500', 'border-red-500');
                input.classList.replace('border-gray-200', 'border-red-500');
                isValid.conf = false;
            }
            msg.classList.remove('hidden'); checkAllValid();
        }

        function startTimer(duration) {
            let timer = duration, minutes, seconds;
            const btnResend = document.getElementById('btn-resend');
            btnResend.disabled = true;
            btnResend.classList.replace('text-gray-500', 'text-gray-400');
            
            if (countdownInterval) clearInterval(countdownInterval);

            countdownInterval = setInterval(function () {
                minutes = parseInt(timer / 60, 10);
                seconds = parseInt(timer % 60, 10);
                document.getElementById('countdown').textContent = (minutes < 10 ? "0" + minutes : minutes) + ":" + (seconds < 10 ? "0" + seconds : seconds);
                
                if (--timer < 0) {
                    clearInterval(countdownInterval);
                    btnResend.disabled = false;
                    btnResend.innerHTML = '<i class="fa-solid fa-rotate-right"></i> ขอรหัสใหม่';
                    btnResend.classList.replace('text-gray-400', 'text-gray-600');
                }
            }, 1000);
        }

        function requestOTP(isResend = false) {
            const email = document.getElementById('email').value.trim();
            const username = document.getElementById('username').value.trim();
            const btn = isResend ? document.getElementById('btn-resend') : document.getElementById('btn-request');

            btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> กำลังส่ง...'; 
            btn.disabled = true;

            fetch('/request-register-otp', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, username })
            }).then(res => res.json().then(data => ({status: res.status, body: data})))
            .then(res => {
                if (res.status === 200) {
                    document.getElementById('display-email').innerText = email;
                    document.getElementById('ref-code').innerText = res.body.refCode; 
                    document.getElementById('step-1').classList.add('hidden');
                    document.getElementById('step-2').classList.remove('hidden');
                    startTimer(60); 
                    Swal.fire({icon:'success', title:'ส่งรหัสแล้ว', text:`ดูเลขอ้างอิง Ref: ${res.body.refCode}`, timer:2000, showConfirmButton:false});
                } else {
                    Swal.fire('ผิดพลาด', res.body.message, 'error');
                    checkAllValid();
                }
            });
        }

        function confirmRegister() {
            const username = document.getElementById('username').value.trim();
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const role = document.getElementById('role').value;
            const otp = document.getElementById('otp').value.trim();
            const btn = document.getElementById('btn-register');

            if(otp.length !== 6) return Swal.fire('แจ้งเตือน', 'กรอก OTP 6 หลัก', 'warning');

            btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> กำลังยืนยัน...'; btn.disabled = true;

            fetch('/register', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, email, password, role, otp })
            }).then(res => res.json().then(data => ({status: res.status, body: data})))
            .then(res => {
                if (res.status === 200) {
                    Swal.fire({icon:'success', title:'สำเร็จ!', text:'สมัครสมาชิกเรียบร้อย', showConfirmButton:false, timer: 1500}).then(() => {
                        window.location.href = '/login';
                    });
                } else {
                    Swal.fire('ผิดพลาด', res.body.message, 'error');
                    btn.innerHTML = '<i class="fa-solid fa-user-check"></i> ยืนยันการสมัคร'; btn.disabled = false;
                }
            });
        }

        function backToStep1() {
            document.getElementById('step-2').classList.add('hidden');
            document.getElementById('step-1').classList.remove('hidden');
        }
    </script>
</body>
</html>