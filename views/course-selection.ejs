<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เลือกระดับชั้น - Grow EDU</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>body { font-family: 'Kanit', sans-serif; }</style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
    
    <nav class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 h-16 flex justify-between items-center">
            <a href="/student" class="text-2xl font-black text-[#1A73E8] hover:scale-105 transition">Grow EDU</a>
            <a href="/student" class="text-gray-500 hover:text-[#1A73E8] font-bold transition flex items-center gap-2">
                <i class="fa-solid fa-house"></i> กลับหน้าแผงควบคุม
            </a>
        </div>
    </nav>

    <div class="max-w-5xl mx-auto p-8 text-center flex-grow flex flex-col justify-center w-full">
        <h1 class="text-3xl md:text-4xl font-bold mb-10 text-gray-800">เลือกระดับชั้นที่ต้องการเรียน 🎒</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <% ['ประถมศึกษา', 'มัธยมต้น', 'มัธยมปลาย'].forEach(level => { %>
                <a href="/courses/<%= level %>" class="bg-white p-10 rounded-3xl shadow-sm border-b-4 border-transparent hover:border-[#1A73E8] hover:shadow-xl hover:-translate-y-2 transition-all duration-300 group flex flex-col items-center">
                    <div class="w-24 h-24 bg-blue-50 rounded-full flex items-center justify-center text-5xl mb-6 group-hover:scale-110 transition-transform duration-300 shadow-inner">
                        <% if(level === 'ประถมศึกษา') { %>👦<% } %>
                        <% if(level === 'มัธยมต้น') { %>🧑‍🎓<% } %>
                        <% if(level === 'มัธยมปลาย') { %>🎓<% } %>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-800 mb-2"><%= level %></h2>
                    <p class="text-gray-500 text-sm mb-6">คลิกเพื่อดูวิชาเรียน</p>
                    <div class="mt-auto bg-[#1A73E8] text-white px-6 py-2 rounded-full font-bold opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-2">
                        เลือกชั้นนี้ <i class="fa-solid fa-arrow-right"></i>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>
</body>
</html>